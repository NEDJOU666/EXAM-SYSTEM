generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN  // Platform owner — controls all tenants
  UNIV_ADMIN   // University admin — manages their tenant
  TEACHER
  STUDENT
}

enum UniversityStatus {
  PENDING    // Registered, awaiting super-admin approval
  ACTIVE
  SUSPENDED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
}

enum ProctoringEventType {
  EXAM_STARTED
  FACE_MISSING
  MULTIPLE_FACES
  GAZE_AWAY
  TAB_BLUR
  FULLSCREEN_EXIT
  COPY_ATTEMPT
  EXAM_SUBMITTED
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student    Student?
  teacher    Teacher?
  univAdmin  UnivAdmin?
  accounts   Account[]
  sessions   Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── University ───────────────────────────────────────────────────────────────

model University {
  id        String           @id @default(cuid())
  name      String
  domain    String           @unique  // e.g. ictuniversity.edu.cm
  slug      String           @unique  // e.g. "ict" → ict.smartexam.app
  status    UniversityStatus @default(ACTIVE)
  country   String?
  phone     String?
  logoUrl   String?
  createdAt DateTime         @default(now())

  students  Student[]
  teachers  Teacher[]
  univAdmin UnivAdmin?
  exams     Exam[]
}

// ─── University Registration Request ─────────────────────────────────────────

model UniversityRegistration {
  id              String             @id @default(cuid())
  name            String
  domain          String
  slug            String             @unique
  contactName     String
  email           String             @unique
  phone           String?
  country         String?
  status          RegistrationStatus @default(PENDING)
  rejectionReason String?            @db.Text
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
}

// ─── Role Profiles ────────────────────────────────────────────────────────────

model UnivAdmin {
  id     String @id @default(cuid())
  userId String @unique
  univId String @unique  // one admin per university

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  univ University @relation(fields: [univId], references: [id])
}

model Student {
  id     String @id @default(cuid())
  userId String @unique
  univId String

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  univ        University       @relation(fields: [univId], references: [id])
  submissions ExamSubmission[]
}

model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  univId String

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  univ  University @relation(fields: [univId], references: [id])
  exams Exam[]
}

// ─── Exam ─────────────────────────────────────────────────────────────────────

model Exam {
  id              String     @id @default(cuid())
  title           String
  description     String?    @db.Text
  duration        Int        // minutes
  rules           String?    @db.Text
  status          ExamStatus @default(DRAFT)
  scheduledAt     DateTime
  proctoringEnabled Boolean  @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  teacherId String
  univId    String

  teacher     Teacher          @relation(fields: [teacherId], references: [id])
  univ        University       @relation(fields: [univId], references: [id])
  questions   Question[]
  submissions ExamSubmission[]
}

model Question {
  id     String       @id @default(cuid())
  text   String       @db.Text
  type   QuestionType @default(MCQ)
  points Int          @default(1)
  order  Int          @default(0)
  examId String

  exam    Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  options Option[]
  answers Answer[]
}

model Option {
  id         String  @id @default(cuid())
  text       String
  isCorrect  Boolean @default(false)
  questionId String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ─── Submissions ──────────────────────────────────────────────────────────────

model ExamSubmission {
  id          String   @id @default(cuid())
  score       Float?
  maxScore    Float?
  submittedAt DateTime @default(now())

  studentId String
  examId    String

  student          Student          @relation(fields: [studentId], references: [id])
  exam             Exam             @relation(fields: [examId], references: [id])
  answers          Answer[]
  proctoringEvents ProctoringEvent[]

  @@unique([studentId, examId])
}

model Answer {
  id               String  @id @default(cuid())
  selectedOptionId String?

  questionId   String
  submissionId String

  question   Question       @relation(fields: [questionId], references: [id])
  submission ExamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

// ─── Proctoring ───────────────────────────────────────────────────────────────

model ProctoringEvent {
  id        String              @id @default(cuid())
  type      ProctoringEventType
  timestamp DateTime            @default(now())
  metadata  Json?               // e.g. { confidence: 0.95, faceCount: 2 }

  submissionId String
  submission   ExamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}
